{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "prod",
      "displayName": "Production (Pi tape OFF)",
      "description": "Release build without Raspberry Pi tape integration",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CASSETTE_BUILD_TESTS": "OFF",
        "CASSETTE_ENABLE_PI_TAPE": "OFF"
      }
    },
    {
      "name": "prod-tests",
      "displayName": "Production + tests",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CASSETTE_BUILD_TESTS": "ON",
        "CASSETTE_ENABLE_PI_TAPE": "OFF"
      }
    },
    {
      "name": "pi-dev",
      "displayName": "Pi tape dev (local only)",
      "description": "Private Raspberry Pi FTP upload build — not for release",
      "binaryDir": "${sourceDir}/build-pi",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CASSETTE_BUILD_TESTS": "ON",
        "CASSETTE_ENABLE_PI_TAPE": "ON"
      }
    },
    {
      "name": "legacy-mac",
      "displayName": "macOS Mojave (Intel x86_64)",
      "description": "Legacy build for macOS 10.14.6+ on Intel Macs",
      "binaryDir": "${sourceDir}/build-legacy",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CASSETTE_BUILD_TESTS": "OFF",
        "CASSETTE_ENABLE_PI_TAPE": "OFF",
        "CASSETTE_LEGACY_MACOS": "ON",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "10.14",
        "CMAKE_OSX_ARCHITECTURES": "x86_64",
        "CASSETTE_BUILD_GSTPEAQ": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "prod-deck",
      "configurePreset": "prod",
      "targets": ["Deck"]
    },
    {
      "name": "prod-tests",
      "configurePreset": "prod-tests",
      "targets": ["DeckTests"]
    },
    {
      "name": "pi-dev-deck",
      "configurePreset": "pi-dev",
      "targets": ["Deck"]
    },
    {
      "name": "legacy-mac-deck",
      "configurePreset": "legacy-mac",
      "targets": ["Deck"]
    }
  ]
}

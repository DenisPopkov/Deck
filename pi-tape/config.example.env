# Copy to /etc/pi-tape/config.env on Raspberry Pi

# local = read uploaded files from PI_TAPE_ROOT/inbox (FTP server on Pi)
# ftp/sftp = fetch from remote server (legacy / dev)
TRANSPORT=local

LOCAL_INBOX=/srv/pi-tape/inbox

# --- FTP fetch mode (only if TRANSPORT=ftp) ---
# FTP_HOST=192.168.1.10
# FTP_PORT=21
# FTP_USER=deck
# FTP_PASS=tape
# FTP_REMOTE_DIR=inbox

# --- Paths on Pi ---
PI_TAPE_ROOT=/srv/pi-tape
STATE_FILE=/var/lib/pi-tape/last_job_id
CONTROL_PORT=8765

# --- Audio ---
# Leave empty for default card; or e.g. plughw:0,0 or plughw:1,0 for USB sound
ALSA_DEVICE=
# Peak normalize when manifest.normalize=true
LOUDNORM_I=-18
LOUDNORM_TP=-3
